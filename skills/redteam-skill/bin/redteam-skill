#!/usr/bin/env python3
"""Umbrella red-team / offensive-security skill.

An agentic loop for AUTHORIZED security testing of a named target from the
outside. The model is the reasoning glue over real tools (HTTP probes + installed
scanners like nuclei), NOT a freehand "hacker". Hard guardrails:

  * AUTHORIZATION GATE — refuses to do anything without an explicit `authorized`
    flag on the invocation.
  * SCOPE ENFORCEMENT — the http tool blocks requests to hosts outside the
    declared target/scope, so the agent cannot wander onto unintended systems.
  * PROOF GATE — a finding may only be 'high'/'critical' if it carries a concrete
    reproduction; unproven suspicions are downgraded. (The offensive-security
    analogue of the code agent's "no green test, no finish".)
  * NON-DESTRUCTIVE — the methodology prompt forbids destructive/DoS/exfil actions.

Reads a job JSON on stdin ({"invocation":{"inputs":{...}}}); emits a JSON report.
"""
from __future__ import annotations

import json, os, sys, subprocess, urllib.request, urllib.error, urllib.parse
from pathlib import Path

MODEL_TIMEOUT = 120
OBS_CAP = 12000
SEVERITIES = ("info", "low", "medium", "high", "critical")
PROOF_REQUIRED = {"high", "critical"}


def _read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def load_model(root: Path) -> dict:
    runtime = root / "control-plane" / "runtime"
    cfg = _read_json(runtime / "model-broker.json")
    secrets = _read_json(runtime / "model-broker.secrets.json")
    routing = cfg.get("routing") if isinstance(cfg.get("routing"), dict) else {}
    conns = cfg.get("connections") if isinstance(cfg.get("connections"), dict) else {}
    cid = "code" if "code" in conns else (str(routing.get("defaultConnectionId", "")).strip() or "default")
    conn = conns.get(cid) if isinstance(conns.get(cid), dict) else {}
    sconn = ((secrets.get("connections") or {}).get(cid) or {}) if isinstance(secrets, dict) else {}
    return {
        "baseUrl": str(conn.get("baseUrl", "")).strip(),
        "model": str(conn.get("defaultModel", "")).strip(),
        "apiKey": str(sconn.get("apiKey", "")).strip(),
    }


def chat_raw(model_cfg: dict, messages: list, tools: list | None = None, temperature: float = 0.1) -> dict:
    payload = {"model": model_cfg["model"], "messages": messages, "temperature": temperature, "max_tokens": 4096}
    if tools:
        payload["tools"] = tools
        payload["tool_choice"] = "auto"
    body = json.dumps(payload).encode("utf-8")
    headers = {"Content-Type": "application/json"}
    if model_cfg["apiKey"]:
        headers["Authorization"] = f"Bearer {model_cfg['apiKey']}"
    url = model_cfg["baseUrl"].rstrip("/") + "/chat/completions"
    for attempt in range(4):
        try:
            req = urllib.request.Request(url, data=body, method="POST", headers=headers)
            with urllib.request.urlopen(req, timeout=MODEL_TIMEOUT) as resp:
                data = json.loads(resp.read().decode("utf-8"))
            return ((data.get("choices") or [{}])[0].get("message")) or {}
        except urllib.error.HTTPError as ex:
            if ex.code not in (429, 500, 502, 503, 504) or attempt == 3:
                raise
        except urllib.error.URLError:
            if attempt == 3:
                raise
    return {}


def _fn(name, desc, props, required):
    return {"type": "function", "function": {"name": name, "description": desc,
            "parameters": {"type": "object", "properties": props, "required": required}}}


TOOLS = [
    _fn("http", "Make ONE HTTP request to the authorized target and return status, headers, and (truncated) body. "
        "This is your primary probing primitive. Requests to hosts outside the declared scope are refused.",
        {"method": {"type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "HEAD", "OPTIONS", "PATCH"]},
         "url": {"type": "string"}, "headers": {"type": "object"}, "body": {"type": "string"}}, ["method", "url"]),
    _fn("run", "Run a shell command to drive an INSTALLED scanner or recon tool (e.g. nuclei, curl, nmap, whatweb) "
        "against the authorized target, and return its output. Prefer proven tools over hand-rolled probing. "
        "No destructive, DoS, or data-exfiltration commands.",
        {"command": {"type": "string"}}, ["command"]),
    _fn("record_finding", "Record a security finding. A finding may be severity 'high' or 'critical' ONLY if you "
        "provide a concrete `reproduction` (the exact request/steps that demonstrate it); without proof it is stored "
        "as 'unconfirmed'.",
        {"severity": {"type": "string", "enum": list(SEVERITIES)}, "title": {"type": "string"},
         "evidence": {"type": "string"}, "reproduction": {"type": "string"}, "remediation": {"type": "string"}},
        ["severity", "title", "evidence"]),
    _fn("finish", "Finish the engagement: the methodology is complete and every high/critical finding is proven. "
        "Provide a short summary.", {"summary": {"type": "string"}}, ["summary"]),
]

SYSTEM = """You are an authorized red-team / offensive-security agent operating STRICTLY within an approved engagement.
You have explicit written authorization to test the named target and MUST stay within the declared scope — never
probe hosts outside it. Work the methodology like a professional:
1. RECON — map the target's surface: reachable endpoints, technology, headers, cookies, auth flows, error behavior.
2. ENUMERATE — find inputs, parameters, roles, object ids, and trust boundaries.
3. TEST — probe real vulnerability classes: broken authentication, broken access control / IDOR, injection (SQL/NoSQL/
   command/template), SSRF, security misconfiguration, secrets/PII exposure, insecure defaults, missing authz on APIs.
   Use the `http` tool for precise probes and the `run` tool to drive INSTALLED scanners (e.g. nuclei) — you are the
   reasoning glue over real tools, not a guesser.
4. VERIFY — for anything that looks exploitable, PROVE it with a concrete reproduction (the exact request/steps and the
   observed result) BEFORE you record it as a real finding.
5. REPORT — record each finding with evidence, a reproduction, and a remediation.

Hard rules:
- Stay in scope. Do NOT perform destructive actions, denial-of-service, account lockout, or exfiltration of real user
  data. A proof-of-concept demonstrates the flaw with the minimum necessary interaction.
- PROOF GATE: severity 'high' or 'critical' REQUIRES a concrete reproduction. An unproven suspicion is 'info' or
  'low', never high. Do not inflate.
- Prefer running a proven scanner and reading its output over hand-rolling. Read tool output carefully before acting.
Call `finish` only when you have worked the methodology and every serious finding is proven."""


def _host(u: str) -> str:
    try:
        return (urllib.parse.urlparse(u if "://" in u else "http://" + u).hostname or "").lower()
    except Exception:
        return ""


def _scope_hosts(target: str, scope: str) -> set:
    hosts = set()
    for tok in [target] + (scope or "").replace(",", " ").split():
        h = _host(tok)
        if h:
            hosts.add(h)
    return hosts


def _in_scope(url: str, allowed: set, scope: str) -> bool:
    if "*" in (scope or ""):
        return True
    h = _host(url)
    return bool(h) and any(h == a or h.endswith("." + a) for a in allowed)


class Engine:
    def __init__(self, target, allowed, scope):
        self.target, self.allowed, self.scope = target, allowed, scope
        self.findings = []

    def http(self, args):
        url = str(args.get("url", "")).strip()
        if not _in_scope(url, self.allowed, self.scope):
            return f"REFUSED: {url} is OUT OF SCOPE. In-scope hosts: {sorted(self.allowed)}. Stay on the authorized target."
        method = str(args.get("method", "GET")).upper()
        headers = {str(k): str(v) for k, v in (args.get("headers") or {}).items()}
        data = str(args.get("body", "")).encode() if args.get("body") else None
        try:
            req = urllib.request.Request(url, data=data, method=method, headers=headers)
            with urllib.request.urlopen(req, timeout=30) as resp:
                body = resp.read(OBS_CAP).decode("utf-8", "replace")
                hdrs = "\n".join(f"{k}: {v}" for k, v in resp.headers.items())
                return f"HTTP {resp.status}\n{hdrs}\n\n{body}"
        except urllib.error.HTTPError as ex:
            body = ex.read(OBS_CAP).decode("utf-8", "replace") if hasattr(ex, "read") else ""
            hdrs = "\n".join(f"{k}: {v}" for k, v in (ex.headers or {}).items())
            return f"HTTP {ex.code}\n{hdrs}\n\n{body}"
        except Exception as ex:  # noqa: BLE001
            return f"request error: {type(ex).__name__}: {ex}"

    def run(self, args):
        cmd = str(args.get("command", "")).strip()
        if not cmd:
            return "no command"
        try:
            p = subprocess.run(["bash", "-lc", cmd], capture_output=True, text=True, timeout=600)
            return f"exit={p.returncode}\n{(p.stdout + p.stderr)[:OBS_CAP]}"
        except subprocess.TimeoutExpired:
            return "command timed out"
        except Exception as ex:  # noqa: BLE001
            return f"run error: {type(ex).__name__}: {ex}"

    def record_finding(self, args):
        sev = str(args.get("severity", "info")).lower().strip()
        if sev not in SEVERITIES:
            sev = "info"
        repro = str(args.get("reproduction", "")).strip()
        downgraded = False
        if sev in PROOF_REQUIRED and not repro:
            sev, downgraded = "unconfirmed", True  # proof gate
        finding = {
            "severity": sev, "title": str(args.get("title", "")).strip(),
            "evidence": str(args.get("evidence", "")).strip(),
            "reproduction": repro, "remediation": str(args.get("remediation", "")).strip(),
        }
        self.findings.append(finding)
        if downgraded:
            return ("Recorded, but DOWNGRADED to 'unconfirmed': high/critical requires a concrete reproduction. "
                    "Prove it with an exact request/steps, then re-record at the real severity.")
        return f"recorded {sev} finding: {finding['title']}"

    def report(self, summary):
        order = {s: i for i, s in enumerate(("critical", "high", "medium", "low", "unconfirmed", "info"))}
        fs = sorted(self.findings, key=lambda f: order.get(f["severity"], 99))
        counts = {}
        for f in fs:
            counts[f["severity"]] = counts.get(f["severity"], 0) + 1
        lines = [f"# Red-team report — {self.target}", "", summary.strip(), "",
                 "## Findings (" + ", ".join(f"{v} {k}" for k, v in counts.items()) + ")" if fs else "## Findings: none", ""]
        for f in fs:
            lines.append(f"### [{f['severity'].upper()}] {f['title']}")
            if f["evidence"]:
                lines.append(f"- **Evidence:** {f['evidence']}")
            if f["reproduction"]:
                lines.append(f"- **Reproduction:** {f['reproduction']}")
            if f["remediation"]:
                lines.append(f"- **Remediation:** {f['remediation']}")
            lines.append("")
        return "\n".join(lines)


def main() -> int:
    try:
        payload = json.loads(sys.stdin.read() or "{}")
    except ValueError:
        print(json.dumps({"ok": False, "error": "invalid JSON on stdin"}))
        return 1
    inputs = (((payload.get("invocation") or {}).get("inputs")) or {}) if isinstance(payload, dict) else {}
    target = str(inputs.get("target", "")).strip()
    if not target:
        print(json.dumps({"ok": False, "error": "'target' is required"}))
        return 1
    # AUTHORIZATION GATE — refuse to probe anything without explicit authorization.
    if not bool(inputs.get("authorized", False)):
        print(json.dumps({"ok": False, "error": "authorization_required",
                          "summary": "Refused: security testing requires explicit authorization. Re-invoke with "
                                     "authorized=true only for a target you own or are contracted to test."}))
        return 0

    scope = str(inputs.get("scope", "")).strip()
    allowed = _scope_hosts(target, scope)
    max_iters = max(4, min(int(inputs.get("maxIterations", 40) or 40), 100))
    thoroughness = str(inputs.get("thoroughness", "standard")).strip()

    root = Path(os.environ.get("UMBRELLA_ROOT") or Path(__file__).resolve().parents[3])
    model_cfg = load_model(root)
    if not model_cfg["baseUrl"] or not model_cfg["model"]:
        print(json.dumps({"ok": False, "error": "no model connection configured for the red-team skill"}))
        return 1

    eng = Engine(target, allowed, scope)
    context = (f"TARGET: {target}\nSCOPE (in-scope hosts): {sorted(allowed)}\nTHOROUGHNESS: {thoroughness}\n"
               f"You have explicit authorization for this engagement. Begin recon.")
    messages = [{"role": "system", "content": SYSTEM}, {"role": "user", "content": context}]
    iters, finished, summary, no_tool = 0, False, "", 0

    while iters < max_iters and not finished:
        iters += 1
        try:
            msg = chat_raw(model_cfg, messages, tools=TOOLS)
        except Exception as ex:  # noqa: BLE001
            summary = f"model error after {iters} step(s): {type(ex).__name__}: {ex}"
            break
        tool_calls = msg.get("tool_calls") or []
        assistant = {"role": "assistant", "content": msg.get("content")}
        if tool_calls:
            assistant["tool_calls"] = tool_calls
        messages.append(assistant)
        if not tool_calls:
            no_tool += 1
            if no_tool >= 2:
                summary = str(msg.get("content") or "").strip() or "stopped without finishing"
                break
            messages.append({"role": "user", "content": "Continue the methodology with a tool, or call finish."})
            continue
        no_tool = 0
        for tc in tool_calls:
            fn = tc.get("function") if isinstance(tc.get("function"), dict) else {}
            name = str(fn.get("name", "")).strip()
            try:
                args = json.loads(fn.get("arguments") or "{}")
            except (ValueError, TypeError):
                args = {}
            if name == "finish":
                summary, finished = str(args.get("summary", "")).strip(), True
                result = "acknowledged"
            elif name == "http":
                result = eng.http(args)
            elif name == "run":
                result = eng.run(args)
            elif name == "record_finding":
                result = eng.record_finding(args if isinstance(args, dict) else {})
            else:
                result = f"unknown tool: {name}"
            messages.append({"role": "tool", "tool_call_id": str(tc.get("id") or ""), "content": str(result)[:OBS_CAP]})
        if finished:
            break

    report = eng.report(summary or "Engagement ended.")
    high = sum(1 for f in eng.findings if f["severity"] in PROOF_REQUIRED)
    print(json.dumps({
        "ok": True,
        "summary": (summary or "engagement ended") + f" — {len(eng.findings)} finding(s), {high} high/critical, "
                   f"{iters} step(s)",
        "report": report,
        "findings": eng.findings,
        "target": target,
        "iterations": iters,
        "verified": finished,
    }))
    return 0


if __name__ == "__main__":
    sys.exit(main())
