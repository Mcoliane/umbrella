#!/usr/bin/env python3
"""Autonomous code agent skill for the Umbrella agent runtime.

Turns the code shop from a snippet runner into a coding agent. Given a task and
a working directory, it runs an agentic loop:

  (repo map) -> locate via search -> read -> plan -> edit -> run tests -> fix -> repeat

The agent starts with a task-ranked repository map (symbol-level, built with the
Python AST plus lightweight multi-language regexes) and a ranked `search` tool,
so it navigates an existing codebase like an engineer instead of reading files
at random. It then does a self-review pass over the git diff and applies fixes.
Changes are git-backed (every run is a diff you can review or revert). Reads the
configured model connection from the platform's model-broker config and calls it
directly, so the loop is a real tool-use agent rather than a single completion.

stdlib only. Reads one invocation as JSON on stdin, emits one JSON object on
stdout.
"""
from __future__ import annotations

import ast
import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.request
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

CONTEXT_BUDGET = 48000     # chars of message history before compaction kicks in
KEEP_RECENT = 8            # most-recent turns always kept verbatim

MAX_ITERATIONS_DEFAULT = 30
CMD_TIMEOUT = 180          # per run() command
MODEL_TIMEOUT = 120        # per model call
OBS_CAP = 6000             # chars of a tool observation fed back to the model
READ_CAP = 24000           # chars returned by read_file
RUN_OUTPUT_CAP = 8000      # chars of command stdout/stderr kept
REPO_MAP_BUDGET = 6000     # chars of the repository map injected at loop start
SEARCH_MAX_RESULTS = 30    # ranked matches returned by the search tool

# Source files the repo map and search scan; everything else is skipped.
SOURCE_EXTS = {
    ".py", ".pyi", ".js", ".jsx", ".ts", ".tsx", ".go", ".rs", ".java", ".rb",
    ".php", ".c", ".h", ".cc", ".cpp", ".hpp", ".cs", ".swift", ".kt", ".scala",
    ".sh", ".bash", ".sql", ".html", ".css", ".json", ".yaml", ".yml", ".toml", ".md",
}
_SKIP_PARTS = {".git", "__pycache__", "node_modules", ".venv", "venv", "dist", "build", ".pytest_cache", ".mypy_cache"}


def _skip_path(p: Path) -> bool:
    return any(part in _SKIP_PARTS for part in p.parts)


# --------------------------------------------------------------------------- #
# Model access — read the configured broker connection and call it directly.
# --------------------------------------------------------------------------- #
def load_model(root: Path) -> dict:
    runtime = root / "control-plane" / "runtime"
    cfg = _read_json(runtime / "model-broker.json")
    secrets = _read_json(runtime / "model-broker.secrets.json")
    routing = cfg.get("routing") if isinstance(cfg.get("routing"), dict) else {}
    conns = cfg.get("connections") if isinstance(cfg.get("connections"), dict) else {}
    # Prefer a dedicated 'code' connection if the operator configured one.
    cid = "code" if "code" in conns else (str(routing.get("defaultConnectionId", "")).strip() or "default")
    conn = conns.get(cid) if isinstance(conns.get(cid), dict) else {}
    sconn = ((secrets.get("connections") or {}).get(cid) or {}) if isinstance(secrets, dict) else {}
    return {
        "baseUrl": str(conn.get("baseUrl", "")).strip(),
        "model": str(conn.get("defaultModel", "")).strip(),
        "apiKey": str(sconn.get("apiKey", "")).strip(),
        "timeoutSec": int(conn.get("timeoutSec", 120) or 120),
    }


def _read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def chat(model_cfg: dict, messages: list, temperature: float = 0.1) -> str:
    body = json.dumps({
        "model": model_cfg["model"],
        "messages": messages,
        "temperature": temperature,
        "max_tokens": 4096,
    }).encode("utf-8")
    headers = {"Content-Type": "application/json"}
    if model_cfg["apiKey"]:
        headers["Authorization"] = f"Bearer {model_cfg['apiKey']}"
    url = model_cfg["baseUrl"].rstrip("/") + "/chat/completions"
    last = None
    for attempt in range(4):
        try:
            req = urllib.request.Request(url, data=body, method="POST", headers=headers)
            with urllib.request.urlopen(req, timeout=MODEL_TIMEOUT) as resp:
                data = json.loads(resp.read().decode("utf-8"))
            return (((data.get("choices") or [{}])[0].get("message") or {}).get("content") or "").strip()
        except urllib.error.HTTPError as ex:
            last = ex
            if ex.code not in (429, 500, 502, 503, 504) or attempt == 3:
                raise
        except urllib.error.URLError as ex:
            last = ex
            if attempt == 3:
                raise
        time.sleep(1.2 * (attempt + 1))
    if last:
        raise last
    return ""


# --------------------------------------------------------------------------- #
# Tools — all confined to the working directory.
# --------------------------------------------------------------------------- #
class Workspace:
    def __init__(self, root: Path):
        self.root = root.resolve()
        self._symbol_index: dict | None = None  # {name: [(rel, line, kind, sig)]}, cached

    def _safe(self, rel: str) -> Path:
        p = (self.root / str(rel or "").lstrip("/")).resolve()
        if p != self.root and self.root not in p.parents:
            raise ValueError(f"path escapes working directory: {rel}")
        return p

    def _source_files(self):
        for p in sorted(self.root.rglob("*")):
            if p.is_file() and p.suffix.lower() in SOURCE_EXTS and not _skip_path(p):
                yield p

    def list_dir(self, rel: str = ".") -> str:
        base = self._safe(rel or ".")
        if not base.exists():
            return f"(no such path: {rel})"
        out = []
        for p in sorted(base.rglob("*"))[:400]:
            if any(part in {".git", "__pycache__", "node_modules", ".venv"} for part in p.parts):
                continue
            rp = p.relative_to(self.root)
            out.append(f"{'d' if p.is_dir() else 'f'} {rp}")
        return "\n".join(out) or "(empty)"

    def read_file(self, rel: str) -> str:
        p = self._safe(rel)
        if not p.is_file():
            return f"(no such file: {rel})"
        text = p.read_text(encoding="utf-8", errors="replace")
        return text[:READ_CAP] + ("\n...(truncated)" if len(text) > READ_CAP else "")

    def write_file(self, rel: str, content: str) -> str:
        p = self._safe(rel)
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(content if isinstance(content, str) else str(content), encoding="utf-8")
        self._symbol_index = None  # code changed; rebuild navigation index on next use
        return f"wrote {rel} ({len(content or '')} chars)"

    def edit_file(self, rel: str, old: str, new: str) -> str:
        p = self._safe(rel)
        if not p.is_file():
            return f"(no such file: {rel})"
        text = p.read_text(encoding="utf-8")
        if old not in text:
            return f"(edit failed: 'old' text not found in {rel})"
        if text.count(old) > 1:
            return f"(edit failed: 'old' text is not unique in {rel}; add more context)"
        p.write_text(text.replace(old, new, 1), encoding="utf-8")
        self._symbol_index = None
        return f"edited {rel}"

    def run(self, command: str) -> str:
        try:
            proc = subprocess.run(
                ["bash", "-lc", command], cwd=str(self.root),
                capture_output=True, text=True, timeout=CMD_TIMEOUT,
            )
        except subprocess.TimeoutExpired:
            return f"(command timed out after {CMD_TIMEOUT}s)"
        out = (proc.stdout or "")[-RUN_OUTPUT_CAP:]
        err = (proc.stderr or "")[-RUN_OUTPUT_CAP:]
        return f"exit={proc.returncode}\n--stdout--\n{out}\n--stderr--\n{err}".strip()

    def find(self, query: str, *, regex: bool = False, whole_word: bool = False,
             case_sensitive: bool = False, glob: str = "", context: int = 0,
             max_results: int = SEARCH_MAX_RESULTS) -> str:
        """VSCode-style Find in Files: search across source files with optional
        regex, whole-word, case sensitivity, a file glob, and N lines of context.
        Returns file:line: text hits, grouped by file."""
        q = str(query or "").strip()
        if not q:
            return "(empty query)"
        flags = 0 if case_sensitive else re.IGNORECASE
        try:
            if regex:
                pat = re.compile(q, flags)
            elif whole_word:
                pat = re.compile(r"\b" + re.escape(q) + r"\b", flags)
            else:
                pat = re.compile(re.escape(q), flags)
        except re.error as ex:
            return f"(invalid regex: {ex})"
        context = max(0, min(int(context or 0), 4))
        glob = str(glob or "").strip()
        out: list[str] = []
        total = 0
        for p in self._source_files():
            rel = p.relative_to(self.root)
            if glob and not p.match(glob) and not Path(str(rel)).match(glob):
                continue
            try:
                lines = p.read_text(encoding="utf-8", errors="replace").splitlines()
            except OSError:
                continue
            file_hits: list[str] = []
            for i, line in enumerate(lines, 1):
                if not pat.search(line):
                    continue
                if context:
                    lo, hi = max(1, i - context), min(len(lines), i + context)
                    for j in range(lo, hi + 1):
                        mark = ">" if j == i else " "
                        file_hits.append(f"  {mark}{j}: {lines[j-1].rstrip()[:160]}")
                    file_hits.append("  --")
                else:
                    file_hits.append(f"  {i}: {line.strip()[:160]}")
                total += 1
                if total >= max_results:
                    break
            if file_hits:
                out.append(f"{rel}:")
                out.extend(file_hits)
            if total >= max_results:
                out.append(f"(stopped at {max_results} matches)")
                break
        return "\n".join(out) or f"(no matches for {query!r})"

    # Back-compat: `search` is a simple ranked find.
    def search(self, query: str, max_results: int = SEARCH_MAX_RESULTS) -> str:
        return self.find(query, max_results=max_results)

    def _sym_index(self) -> dict:
        if self._symbol_index is None:
            index: dict[str, list] = {}
            for p in self._source_files():
                try:
                    text = p.read_text(encoding="utf-8", errors="replace")
                except OSError:
                    continue
                rel = str(p.relative_to(self.root))
                for d in _definitions(p, text):
                    index.setdefault(d["name"], []).append((rel, d["line"], d["kind"], d["sig"]))
            self._symbol_index = index
        return self._symbol_index

    def definition(self, symbol: str) -> str:
        """Go to Definition: where a function/class/method/symbol is DEFINED."""
        name = str(symbol or "").strip().split("(")[0].split(".")[-1]
        if not name:
            return "(no symbol given)"
        hits = self._sym_index().get(name, [])
        if not hits:
            return f"(no definition found for {name!r}; try `find` for text matches)"
        return "\n".join(f"{rel}:{line}: {sig}" for rel, line, kind, sig in hits[:20])

    def references(self, symbol: str, max_results: int = SEARCH_MAX_RESULTS) -> str:
        """Find All References: where a symbol is USED across the codebase."""
        name = str(symbol or "").strip().split("(")[0].split(".")[-1]
        if not name:
            return "(no symbol given)"
        rx = re.compile(r"\b" + re.escape(name) + r"\b")
        out: list[str] = []
        for p in self._source_files():
            rel = p.relative_to(self.root)
            try:
                lines = p.read_text(encoding="utf-8", errors="replace").splitlines()
            except OSError:
                continue
            for i, line in enumerate(lines, 1):
                if rx.search(line):
                    out.append(f"{rel}:{i}: {line.strip()[:150]}")
                    if len(out) >= max_results:
                        return "\n".join(out) + f"\n(stopped at {max_results})"
        return "\n".join(out) or f"(no references found for {name!r})"

    def outline(self, rel: str) -> str:
        """Go to Symbol: list the definitions in a single file with line numbers."""
        p = self._safe(rel)
        if not p.is_file():
            return f"(no such file: {rel})"
        text = p.read_text(encoding="utf-8", errors="replace")
        defs = _definitions(p, text)
        if not defs:
            return f"(no symbols in {rel})"
        return "\n".join(f"L{d['line']}: {d['sig']}" for d in defs[:80])


# --------------------------------------------------------------------------- #
# Repository map — give the agent a symbol-level view of the codebase up front,
# ranked toward the task, so it navigates like an engineer instead of guessing.
# --------------------------------------------------------------------------- #
def _extract_symbols(path: Path, text: str) -> list[str]:
    """Top-level symbols (functions/classes/etc.) with a line number. Python uses
    the AST; other languages use lightweight regexes."""
    out: list[str] = []
    if path.suffix.lower() in {".py", ".pyi"}:
        try:
            tree = ast.parse(text)
        except (SyntaxError, ValueError):
            return out
        for node in tree.body:  # top-level only, keeps the map compact
            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
                args = ", ".join(a.arg for a in node.args.args)
                out.append(f"def {node.name}({args})  L{node.lineno}")
            elif isinstance(node, ast.ClassDef):
                methods = [n.name for n in node.body if isinstance(n, (ast.FunctionDef, ast.AsyncFunctionDef))]
                m = (" {" + ", ".join(methods[:8]) + "}") if methods else ""
                out.append(f"class {node.name}{m}  L{node.lineno}")
        return out
    patterns = (
        r"^\s*(?:export\s+)?(?:default\s+)?(?:async\s+)?function\s+(\w+)\s*\(",
        r"^\s*(?:export\s+)?(?:abstract\s+)?class\s+(\w+)",
        r"^\s*(?:export\s+)?const\s+(\w+)\s*=\s*(?:async\s*)?\(",
        r"^\s*func\s+(?:\([^)]*\)\s*)?(\w+)\s*\(",   # Go
        r"^\s*(?:pub\s+)?fn\s+(\w+)",                # Rust
        r"^\s*type\s+(\w+)\s+struct",                # Go struct
        r"^\s*(?:public|private|protected).*\s(\w+)\s*\(",  # Java-ish
    )
    compiled = [re.compile(p) for p in patterns]
    for i, line in enumerate(text.splitlines(), 1):
        for rx in compiled:
            m = rx.match(line)
            if m:
                out.append(f"{m.group(1)}  L{i}")
                break
        if len(out) >= 40:
            break
    return out


def _definitions(path: Path, text: str) -> list[dict]:
    """All definitions (functions/classes/methods/etc.) as structured records
    {name, kind, line, sig} — backs `definition`, `references`, and `outline`.
    Python uses the AST (includes methods); others use lightweight regexes."""
    defs: list[dict] = []
    if path.suffix.lower() in {".py", ".pyi"}:
        try:
            tree = ast.parse(text)
        except (SyntaxError, ValueError):
            return defs
        for node in ast.walk(tree):
            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
                args = ", ".join(a.arg for a in node.args.args)
                defs.append({"name": node.name, "kind": "def", "line": node.lineno, "sig": f"def {node.name}({args})"})
            elif isinstance(node, ast.ClassDef):
                defs.append({"name": node.name, "kind": "class", "line": node.lineno, "sig": f"class {node.name}"})
        defs.sort(key=lambda d: d["line"])
        return defs
    patterns = [
        ("function", r"^\s*(?:export\s+)?(?:default\s+)?(?:async\s+)?function\s+(\w+)"),
        ("class", r"^\s*(?:export\s+)?(?:abstract\s+)?class\s+(\w+)"),
        ("const", r"^\s*(?:export\s+)?const\s+(\w+)\s*=\s*(?:async\s*)?\("),
        ("func", r"^\s*func\s+(?:\([^)]*\)\s*)?(\w+)\s*\("),
        ("fn", r"^\s*(?:pub\s+)?fn\s+(\w+)"),
        ("type", r"^\s*type\s+(\w+)\s+struct"),
    ]
    compiled = [(k, re.compile(p)) for k, p in patterns]
    for i, line in enumerate(text.splitlines(), 1):
        for kind, rx in compiled:
            m = rx.match(line)
            if m:
                defs.append({"name": m.group(1), "kind": kind, "line": i, "sig": line.strip()[:120]})
                break
    return defs


def build_repo_map(root: Path, task: str, budget: int = REPO_MAP_BUDGET) -> str:
    files = [p for p in root.rglob("*")
             if p.is_file() and p.suffix.lower() in SOURCE_EXTS and not _skip_path(p)]
    if not files:
        return ""
    keywords = {w for w in re.findall(r"\w+", task.lower()) if len(w) > 2}
    entries: list[tuple[float, str]] = []
    for p in files[:600]:
        try:
            text = p.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        symbols = _extract_symbols(p, text)
        rel = str(p.relative_to(root))
        score = sum(3 for k in keywords if k in rel.lower())
        for s in symbols:
            name = re.split(r"[ ({]", s, 1)[0].lower()
            if name in keywords:
                score += 5
        score += min(len(symbols), 12) * 0.2  # bigger/central files rank a bit higher
        block = rel + ":" + ("".join(f"\n    {s}" for s in symbols[:14]) if symbols else " (no top-level symbols)")
        entries.append((score, block))
    entries.sort(key=lambda e: e[0], reverse=True)
    lines, used = ["Repository map (most task-relevant files first; use `search` to find more):"], 0
    for _, block in entries:
        if used + len(block) > budget:
            break
        lines.append(block)
        used += len(block) + 1
    return "\n".join(lines)


# --------------------------------------------------------------------------- #
# Git — checkpoint before, diff after.
# --------------------------------------------------------------------------- #
def git(root: Path, *args: str) -> subprocess.CompletedProcess:
    return subprocess.run(["git", "-C", str(root), *args], capture_output=True, text=True, timeout=60)


def ensure_repo(root: Path) -> None:
    if not (root / ".git").exists():
        git(root, "init")
        git(root, "add", "-A")
        git(root, "-c", "user.email=agent@umbrella", "-c", "user.name=umbrella-code-agent", "commit", "-m", "checkpoint: before code agent", "--allow-empty")
    else:
        git(root, "add", "-A")
        git(root, "-c", "user.email=agent@umbrella", "-c", "user.name=umbrella-code-agent", "commit", "-m", "checkpoint: before code agent", "--allow-empty")


def working_diff(root: Path) -> str:
    git(root, "add", "-A")
    d = git(root, "diff", "--cached", "--stat")
    full = git(root, "diff", "--cached")
    return (d.stdout or "") + "\n" + (full.stdout or "")[:20000]


# --------------------------------------------------------------------------- #
# Agent protocol.
# --------------------------------------------------------------------------- #
SYSTEM = """You are an elite software engineer operating as an autonomous coding agent inside a git-backed working directory. You write clean, correct, idiomatic, PROFESSIONAL code with sensible structure, error handling, docstrings/comments where they add value, and tests.

You work strictly by TOOLS. On every turn you MUST reply with a SINGLE JSON object and NOTHING ELSE (no prose, no markdown fences). Navigation & editing tools (like an IDE):
  {"tool":"find","query":"<text or regex>","regex":false,"whole_word":false,"case_sensitive":false,"glob":"","context":0}  # Find in Files; options are optional
  {"tool":"definition","symbol":"<name>"}            # Go to Definition: where a function/class/method is defined
  {"tool":"references","symbol":"<name>"}            # Find All References: everywhere a symbol is used
  {"tool":"outline","path":"relative/path"}          # Go to Symbol: list the definitions in one file
  {"tool":"list_dir","path":"."}
  {"tool":"read_file","path":"relative/path"}
  {"tool":"write_file","path":"relative/path","content":"<full file content>"}
  {"tool":"edit_file","path":"relative/path","old":"<exact unique snippet>","new":"<replacement>"}
  {"tool":"run","command":"<shell command run in the working dir>"}
  {"tool":"finish","summary":"<what you built and how it was verified>"}

Method (follow it):
1. You are given a Repository map of the codebase up front. Use `find` (text/regex), `definition`, `references`, and `outline` to locate the exact code relevant to the task — navigate like an engineer, do NOT read files at random on a large codebase.
2. Read the specific code you'll change or depend on, then plan briefly and implement in small steps. When the task does not specify a FORM, choose the one that fits the domain and state which you chose: a user-facing, interactive product (photo editor, game, dashboard) should be a real UI (web or desktop), NOT a command-line tool; batch/automation/data work should be a CLI or library; a backend should be a service/API.
3. VERIFY your work with the installed test runner (e.g. pytest/node): write and RUN tests that exercise REAL BEHAVIOR and output — not merely that a pure helper returns a value, but that the actual feature does the right thing (e.g. the image is actually transformed, the endpoint returns the right response) — plus linters/type-checkers/build commands via the run tool. Read the output. If anything fails, FIX it and re-run. Do not finish on unverified code.
4. Prefer edit_file for surgical changes to existing files and write_file for new/rewritten files. Keep files complete and runnable, and match the surrounding code's style and conventions.
5. INTEGRATION IS PART OF THE JOB — the project must actually RUN AS A WHOLE from its real entry point, not merely pass unit tests. Before finishing, exercise the ACTUAL entry point (load the HTML page in a headless/DOM check, run the CLI, import the package/module) and confirm the pieces are wired together. A task is NOT done — even when unit tests pass — if any of these is true:
   - a source file you wrote is never loaded by a <script> tag or imported/required anywhere (dead/orphaned code);
   - the code references DOM element ids, global names, module exports, or function APIs that no file actually defines (e.g. calling window.foo when the module exports window.Foo, or getElementById('x') when the HTML has no id="x");
   - it works in unit tests but not when launched from its real entry point (the HTML page, the CLI, the server).
6. Only call finish when the task is complete, wired together end to end, AND your verification commands pass.

Rules: emit exactly one JSON object per turn. Keep going until done; do not ask the user questions. Use the tools and libraries ALREADY INSTALLED on this machine (an inventory is provided in your context) — reach for the professional library/framework/runtime that fits the job (a real web framework, an image library like Pillow, a proper test runner) instead of hand-rolling everything from stdlib. Do NOT download or install new dependencies (no pip/npm/cargo install, etc.) unless the task explicitly says so; if the ideal tool is not installed, use the best one that IS."""


def parse_action(text: str) -> dict:
    s = text.strip()
    if s.startswith("```"):
        s = s.split("\n", 1)[-1]
        if s.rstrip().endswith("```"):
            s = s.rstrip()[:-3]
    # Grab the outermost JSON object.
    start, depth, in_str, esc = s.find("{"), 0, False, False
    if start >= 0:
        for i in range(start, len(s)):
            c = s[i]
            if in_str:
                esc = (c == "\\" and not esc)
                if c == '"' and not esc:
                    in_str = False
            else:
                if c == '"':
                    in_str = True
                elif c == "{":
                    depth += 1
                elif c == "}":
                    depth -= 1
                    if depth == 0:
                        s = s[start:i + 1]
                        break
    try:
        obj = json.loads(s)
        return obj if isinstance(obj, dict) else {"tool": "_error", "error": "not an object"}
    except ValueError as ex:
        return {"tool": "_error", "error": f"could not parse JSON action: {ex}"}


def _chars(messages: list) -> int:
    return sum(len(str(m.get("content", ""))) for m in messages)


def trim_messages(messages: list) -> list:
    """Keep the loop within a context budget: always retain the system prompt and
    the task, keep the most recent turns verbatim, and compact the middle into a
    short 'progress so far' note (older file reads/writes are the main bloat)."""
    if len(messages) <= 2 + KEEP_RECENT or _chars(messages) <= CONTEXT_BUDGET:
        return messages
    head, tail = messages[:2], messages[-KEEP_RECENT:]
    actions = []
    for m in messages[2:-KEEP_RECENT]:
        if m.get("role") != "assistant":
            continue
        a = parse_action(str(m.get("content", "")))
        t = a.get("tool")
        if t == "write_file":
            actions.append(f"wrote {a.get('path')}")
        elif t == "edit_file":
            actions.append(f"edited {a.get('path')}")
        elif t == "run":
            actions.append(f"ran `{str(a.get('command', ''))[:70]}`")
        elif t == "read_file":
            actions.append(f"read {a.get('path')}")
        elif t in ("find", "search"):
            actions.append(f"found `{str(a.get('query', ''))[:40]}`")
        elif t in ("definition", "references"):
            actions.append(f"{t} {a.get('symbol')}")
        elif t == "outline":
            actions.append(f"outline {a.get('path')}")
    note = "PROGRESS SO FAR (older steps compacted to save context): " + "; ".join(actions[-60:] or ["(none)"])
    return head + [{"role": "user", "content": note}] + tail


def plan_subtasks(model_cfg: dict, ws: Workspace, task: str) -> dict:
    """Ask the model to decompose the task into independent, disjoint-file subtasks
    that can be built in parallel, AND define the shared interface contract the
    workers must build against. Parallel workers cannot see each other's code, so
    without a contract they invent divergent names (canvas vs main-canvas,
    window.Foo vs window.foo) and the parts never connect. Returns
    {parallelizable, interfaceContract, subtasks:[{title,detail,files}]}."""
    try:
        content = chat(model_cfg, [
            {"role": "system", "content":
                "You are a tech lead planning parallel work. Decompose the task into INDEPENDENT subtasks that "
                "touch DISJOINT files so separate workers can build them at the same time without conflicting. "
                "CRITICAL: the workers CANNOT see each other's code, so you MUST define the shared INTERFACE "
                "CONTRACT they will all build against — the exact names that connect the files. Be concrete and "
                "prescriptive: the entry-point file and what it loads; every file path; the exact DOM element ids "
                "(for web UIs); the global/module names each file EXPORTS and each file CONSUMES; and the "
                "signatures of any functions called across file boundaries. "
                "Do NOT force it: if the task is small or inherently sequential, set parallelizable=false. "
                "Reply with ONLY one JSON object: "
                '{"parallelizable": true|false, "interfaceContract": str, '
                '"subtasks": [{"title": str, "detail": str, "files": [str]}]}. '
                "Aim for 2-4 subtasks when parallelizable. Each subtask's files must not overlap another's. "
                "Example interfaceContract: \"Entry: index.html loads <script src='js/engine.js'> then "
                "<script src='js/app.js'>. Canvas id='main-canvas'; sliders id='slider-brightness' etc. "
                "js/engine.js exports window.Engine with brightness(imageData, amount)->ImageData, "
                "grayscale(imageData)->ImageData. js/app.js reads document.getElementById('slider-brightness') "
                "and calls window.Engine.brightness; it also reads getImageData/putImageData on '#main-canvas'.\""},
            {"role": "user", "content":
                f"TASK:\n{task}\n\n{_ENV_SURVEY}\n\n"
                "Choose the professional stack AND the appropriate FORM for this task from the tools ALREADY "
                "INSTALLED above (a user-facing interactive product -> a real UI, not a CLI; automation/data -> a "
                "CLI or library; a backend -> a service/API) rather than hand-rolling from stdlib; do not require "
                "any download. Reflect the stack and form in the subtasks and the contract.\n\n"
                f"Working dir currently:\n{ws.list_dir('.')}"},
        ], temperature=0.0)
        obj = parse_action(content)
        if isinstance(obj, dict) and isinstance(obj.get("subtasks"), list):
            obj.setdefault("interfaceContract", "")
            return obj
    except Exception:  # noqa: BLE001 — planning is best-effort; fall back to a single loop
        pass
    return {"parallelizable": False, "subtasks": [], "interfaceContract": ""}


# Filled once at startup by survey_environment(); injected into every planner and
# worker so the agent builds with the professional tools ALREADY on this machine
# instead of assuming bare stdlib. Empty string => survey unavailable (graceful).
_ENV_SURVEY = ""

# Probes run through the SAME login shell the build uses (bash -lc), so anything
# the survey reports is genuinely runnable by the agent. No network, no installs.
_SURVEY_SCRIPT = r'''
ver(){ case "$1" in go) go version 2>&1;; *) "$1" --version 2>&1 || "$1" -version 2>&1;; esac | head -1; }
for t in python3 node deno bun ruby php go rustc java gcc clang swift perl Rscript; do
  command -v "$t" >/dev/null 2>&1 && echo "RT|$t|$(ver "$t")"
done
for t in git make cmake docker podman sqlite3 ffmpeg magick convert jq pandoc dot curl wget pytest npm cargo pip3; do
  command -v "$t" >/dev/null 2>&1 && echo "TOOL|$t"
done
command -v python3 >/dev/null 2>&1 && python3 - <<'PYEOF' 2>/dev/null
for name, imp in [("fastapi","fastapi"),("flask","flask"),("django","django"),("uvicorn","uvicorn"),
    ("sqlalchemy","sqlalchemy"),("pydantic","pydantic"),("numpy","numpy"),("pandas","pandas"),
    ("pillow","PIL"),("requests","requests"),("aiohttp","aiohttp"),("httpx","httpx"),("jinja2","jinja2"),
    ("click","click"),("rich","rich"),("matplotlib","matplotlib"),("scipy","scipy"),("pytest","pytest"),
    ("beautifulsoup4","bs4"),("lxml","lxml"),("openpyxl","openpyxl")]:
    try:
        m = __import__(imp); print("PY|%s|%s" % (name, getattr(m, "__version__", "?")))
    except Exception:
        pass
PYEOF
'''


def survey_environment() -> str:
    """Detect the toolchain ALREADY INSTALLED on this machine (runtimes, CLIs, and
    importable Python libraries) so the agent reaches for the professional tool
    that's present instead of hand-rolling from stdlib. Runs once; only version
    probes — no network, no installs."""
    try:
        proc = subprocess.run(["bash", "-lc", _SURVEY_SCRIPT], capture_output=True, text=True, timeout=30)
        out = proc.stdout or ""
    except Exception:  # noqa: BLE001 — best-effort; empty survey just restores old behavior
        return ""
    runtimes, tools, pylibs = [], [], []
    for line in out.splitlines():
        parts = line.split("|")
        if parts[0] == "RT" and len(parts) >= 3:
            runtimes.append(f"{parts[1]} ({parts[2].strip()})")
        elif parts[0] == "TOOL" and len(parts) >= 2:
            tools.append(parts[1])
        elif parts[0] == "PY" and len(parts) >= 3:
            pylibs.append(f"{parts[1]} {parts[2].strip()}")
    if not (runtimes or tools or pylibs):
        return ""
    lines = ["AVAILABLE TOOLCHAIN ON THIS MACHINE — these are ALREADY INSTALLED; reach for the professional "
             "library/framework/runtime from this list for the job. Do NOT download or install new dependencies "
             "(no pip/npm/cargo install) unless the task explicitly says so."]
    if runtimes:
        lines.append("  Runtimes/compilers: " + ", ".join(runtimes))
    if tools:
        lines.append("  CLIs/build tools: " + ", ".join(sorted(tools)))
    if pylibs:
        lines.append("  Python libraries importable now (no install needed): " + ", ".join(sorted(pylibs)))
    return "\n".join(lines)


def run_loop(model_cfg: dict, ws: Workspace, task: str, max_iters: int, extra_system: str = "") -> tuple[list, int, bool]:
    repo_map = build_repo_map(ws.root, task)
    context = f"TASK:\n{task}\n\nThe working directory currently contains:\n{ws.list_dir('.')}"
    if _ENV_SURVEY:
        context += f"\n\n{_ENV_SURVEY}"
    if repo_map:
        context += f"\n\n{repo_map}"
    messages = [{"role": "system", "content": SYSTEM + (("\n\n" + extra_system) if extra_system else "")},
                {"role": "user", "content": context}]
    verified = False
    iters = 0
    for iters in range(1, max_iters + 1):
        content = chat(model_cfg, trim_messages(messages))
        messages.append({"role": "assistant", "content": content})
        action = parse_action(content)
        tool = str(action.get("tool", "")).strip()
        try:
            if tool == "finish":
                verified = True
                messages.append({"role": "user", "content": "acknowledged"})
                break
            elif tool == "find":
                obs = ws.find(
                    str(action.get("query", "")),
                    regex=bool(action.get("regex", False)),
                    whole_word=bool(action.get("whole_word", False)),
                    case_sensitive=bool(action.get("case_sensitive", False)),
                    glob=str(action.get("glob", "")),
                    context=int(action.get("context", 0) or 0),
                )
            elif tool == "search":
                obs = ws.search(str(action.get("query", "")))
            elif tool == "definition":
                obs = ws.definition(str(action.get("symbol", "")))
            elif tool == "references":
                obs = ws.references(str(action.get("symbol", "")))
            elif tool == "outline":
                obs = ws.outline(str(action.get("path", "")))
            elif tool == "list_dir":
                obs = ws.list_dir(str(action.get("path", ".")))
            elif tool == "read_file":
                obs = ws.read_file(str(action.get("path", "")))
            elif tool == "write_file":
                obs = ws.write_file(str(action.get("path", "")), action.get("content", ""))
            elif tool == "edit_file":
                obs = ws.edit_file(str(action.get("path", "")), str(action.get("old", "")), str(action.get("new", "")))
            elif tool == "run":
                obs = ws.run(str(action.get("command", "")))
            elif tool == "_error":
                obs = f"Your last message was not a valid single JSON action: {action.get('error')}. Reply with exactly one JSON tool object."
            else:
                obs = f"Unknown tool {tool!r}. Use one of find, definition, references, outline, list_dir, read_file, write_file, edit_file, run, finish."
        except Exception as ex:  # noqa: BLE001 — surface tool errors back to the agent
            obs = f"(tool error: {type(ex).__name__}: {ex})"
        messages.append({"role": "user", "content": str(obs)[:OBS_CAP]})
    return messages, iters, verified


def _resolve_js_import(base: Path, spec: str) -> Path | None:
    """Resolve a relative JS require()/import specifier to a real file, applying
    Node-style resolution (bare path, .js/.mjs suffix, or a directory index)."""
    cand = base / spec
    for t in (cand, Path(str(cand) + ".js"), Path(str(cand) + ".mjs"), cand / "index.js"):
        try:
            if t.is_file():
                return t.resolve()
        except OSError:
            continue
    return None


def integration_check(ws: Workspace) -> list[str]:
    """Deterministic, stdlib-only wiring gate. Catches the cross-file integration
    failures unit tests never exercise: <script>/import targets that don't exist,
    DOM ids referenced in JS but absent from every HTML file, source files that
    are never loaded or imported (orphaned/dead code), and window.* globals that
    are consumed under a different name/case than they are defined. Returns a list
    of concrete, human-readable problems (empty == structurally wired)."""
    root = Path(ws.root)
    skip = {".git", "node_modules", ".venv", "venv", "dist", "build", "__pycache__"}

    def _iter(*exts):
        for p in root.rglob("*"):
            if p.suffix.lower() not in exts or not p.is_file():
                continue
            if any(part in skip for part in p.relative_to(root).parts):
                continue
            yield p

    def _read(p: Path) -> str:
        try:
            return p.read_text(encoding="utf-8", errors="ignore")
        except Exception:  # noqa: BLE001
            return ""

    def _rel(p: Path) -> str:
        return str(p.relative_to(root))

    problems: list[str] = []
    html_files = list(_iter(".html", ".htm"))
    js_files = [p for p in _iter(".js", ".mjs") if not p.name.endswith((".test.js", ".spec.js"))]

    html_ids: set[str] = set()
    script_srcs: set[str] = set()
    for hp in html_files:
        txt = _read(hp)
        html_ids.update(re.findall(r'id\s*=\s*["\']([^"\']+)["\']', txt))
        for src in re.findall(r'<script[^>]*\bsrc\s*=\s*["\']([^"\']+)["\']', txt, re.I):
            if re.match(r'^(?:https?:)?//', src):  # external CDN — not our file
                continue
            target = (hp.parent / src)
            if not target.is_file():
                problems.append(f"{_rel(hp)} loads <script src=\"{src}\"> but that file does not exist")
            else:
                script_srcs.add(str(target.resolve()))

    defined_globals: dict[str, str] = {}
    consumed_globals: dict[str, str] = {}
    imported_targets: set[str] = set()
    for jp in js_files:
        txt = _read(jp)
        for name in re.findall(r'window\.([A-Za-z_$][\w$]*)\s*=', txt):
            defined_globals.setdefault(name, _rel(jp))
        for name in re.findall(r'window\.([A-Za-z_$][\w$]*)(?!\s*=)', txt):
            consumed_globals.setdefault(name, _rel(jp))
        specs = (re.findall(r'require\(\s*["\'](\.[^"\']+)["\']\s*\)', txt)
                 + re.findall(r'from\s+["\'](\.[^"\']+)["\']', txt)
                 + re.findall(r'import\s+["\'](\.[^"\']+)["\']', txt))
        for spec in specs:
            resolved = _resolve_js_import(jp.parent, spec)
            if resolved is None:
                problems.append(f"{_rel(jp)} imports \"{spec}\" but no such file exists")
            else:
                imported_targets.add(str(resolved))
        if html_files:  # DOM ids only meaningful when there is a page to host them
            refs = re.findall(r'getElementById\(\s*["\']([^"\']+)["\']\s*\)', txt)
            refs += re.findall(r'querySelector(?:All)?\(\s*["\']#([\w-]+)["\']', txt)
            for rid in refs:
                if rid not in html_ids:
                    problems.append(f"{_rel(jp)} references element id '#{rid}' that no HTML file defines")

    # Orphaned source: a non-test JS file loaded by nothing (no <script>, no import).
    for jp in js_files:
        ap = str(jp.resolve())
        if ap in script_srcs or ap in imported_targets:
            continue
        if not html_files and jp.name in {"index.js", "main.js", "server.js", "cli.js"}:
            continue  # legitimate standalone Node entry point
        problems.append(f"{_rel(jp)} is never loaded by a <script> tag or imported by another module (orphaned/dead code)")

    # Global consumed under a different name/case than it is defined.
    defined_lower = {d.lower(): d for d in defined_globals}
    for name, where in consumed_globals.items():
        if name in defined_globals:
            continue
        if name.lower() in defined_lower:
            problems.append(
                f"{where} uses window.{name} but it is defined as window.{defined_lower[name.lower()]} "
                "(name/case mismatch — they will not connect)")
    seen: set[str] = set()
    return [p for p in problems if not (p in seen or seen.add(p))]


def main() -> int:
    try:
        payload = json.loads(sys.stdin.read() or "{}")
    except ValueError:
        print(json.dumps({"ok": False, "error": "invalid JSON on stdin"}))
        return 1
    invocation = payload.get("invocation") if isinstance(payload.get("invocation"), dict) else {}
    inputs = invocation.get("inputs") if isinstance(invocation.get("inputs"), dict) else {}

    task = str(inputs.get("task", "")).strip()
    if not task:
        print(json.dumps({"ok": False, "error": "'task' is required"}))
        return 1

    root = Path(os.environ.get("UMBRELLA_ROOT") or Path(__file__).resolve().parents[3])
    model_cfg = load_model(root)
    if not model_cfg["baseUrl"] or not model_cfg["model"]:
        print(json.dumps({"ok": False, "error": "no model connection configured for the code agent (run umbrella-setup)"}))
        return 1

    working = str(inputs.get("workingDir", "")).strip() or os.path.expanduser("~/umbrella-code")
    wd = Path(os.path.expanduser(working)).resolve()
    wd.mkdir(parents=True, exist_ok=True)
    ws = Workspace(wd)
    max_iters = max(4, min(int(inputs.get("maxIterations", MAX_ITERATIONS_DEFAULT) or MAX_ITERATIONS_DEFAULT), 60))

    try:
        ensure_repo(wd)
        global _ENV_SURVEY
        _ENV_SURVEY = survey_environment()
        want_parallel = bool(inputs.get("parallel", True))
        max_workers = max(1, min(int(inputs.get("maxWorkers", 4) or 4), 6))
        plan = plan_subtasks(model_cfg, ws, task) if want_parallel else {"parallelizable": False, "subtasks": []}
        subtasks = [s for s in (plan.get("subtasks") or []) if isinstance(s, dict) and s.get("files")][:8]
        contract = str(plan.get("interfaceContract", "")).strip()
        iters = 0
        strategy = "single"

        if plan.get("parallelizable") and len(subtasks) >= 2:
            strategy = f"parallel({len(subtasks)} workers)"

            def _work(st: dict) -> int:
                owned = [str(f) for f in (st.get("files") or [])]
                extra = (
                    "You are ONE of several workers building a project IN PARALLEL. "
                    f"Create/edit ONLY these files: {owned}. Do NOT touch any other file.\n"
                    + (f"\nSHARED INTERFACE CONTRACT — you CANNOT see the other workers' code, so you MUST match "
                       f"these EXACT names/ids/signatures wherever your files connect to theirs:\n{contract}\n"
                       if contract else "")
                    + "\nVerify only your own files (e.g. python3 -m py_compile <file>, or import them); the "
                    "integrator runs the full test suite AND an automated wiring check afterwards. Use the exact "
                    "ids / global names / APIs from the contract so the parts connect. Call finish when your files are done."
                )
                _, it, _ = run_loop(
                    model_cfg, ws, f"{st.get('title', 'subtask')}: {st.get('detail', '')}",
                    max_iters=max(6, max_iters // 2), extra_system=extra,
                )
                return it

            with ThreadPoolExecutor(max_workers=max_workers) as pool:
                iters += sum(pool.map(_work, subtasks))

            built = sorted({str(f) for st in subtasks for f in (st.get("files") or [])})
            _, it, verified = run_loop(
                model_cfg, ws,
                "Parallel workers built these files: " + ", ".join(built) +
                ".\nIntegrate them into a coherent, working project for the original task: make the entry point "
                "load/import every part, make every cross-file id / global / API match, wire up or remove any "
                "orphaned file, then RUN THE FULL TEST SUITE and exercise the REAL entry point until it works.\n"
                + (f"\nSHARED INTERFACE CONTRACT the parts were built against:\n{contract}\n" if contract else "")
                + f"\nORIGINAL TASK:\n{task}",
                max_iters=max_iters,
                extra_system="You are the integrator. Wire the parallel parts together so the project RUNS end to "
                "end from its real entry point (not just unit tests), and verify it.",
            )
            iters += it
        else:
            _, it, verified = run_loop(model_cfg, ws, task, max_iters)
            iters += it

        # Deterministic integration gate: catch cross-file wiring failures that
        # unit tests never exercise, and force a fix loop until the parts connect.
        wiring_problems: list[str] = []
        for _ in range(2):
            wiring_problems = integration_check(ws)
            if not wiring_problems:
                break
            _, wfix, wverified = run_loop(
                model_cfg, ws,
                "The project has these INTEGRATION / WIRING defects — unit tests passing is NOT enough, it must "
                "run end to end from its real entry point:\n- " + "\n- ".join(wiring_problems) +
                "\n\nFix the wiring so every file is loaded/imported, every referenced id / module / global / API "
                "exists and matches, and nothing is orphaned. Then re-verify by exercising the actual entry point.\n\n"
                f"ORIGINAL TASK:\n{task}",
                max_iters=max(6, max_iters // 2),
                extra_system="You are fixing concrete cross-file integration defects so the parts actually connect.",
            )
            iters += wfix
            verified = verified or wverified
        wiring_problems = integration_check(ws)

        review = inputs.get("review", True)
        if review:
            diff = working_diff(wd)
            inventory = ws.list_dir(".")
            wiring_note = ("Automated wiring check: no structural problems found."
                           if not wiring_problems
                           else "Automated wiring check still flags:\n- " + "\n- ".join(wiring_problems))
            critique = chat(model_cfg, [
                {"role": "system", "content": "You are a senior code reviewer doing an INTEGRATION-FIRST review. "
                    "Beyond per-file correctness, bugs, edge cases, and professionalism, verify the project actually "
                    "works AS A WHOLE from its real entry point: the entry point loads/imports every module it needs; "
                    "there are no orphaned files (code never loaded or imported); every cross-file name matches (DOM "
                    "ids, global/module names, function signatures, APIs); and it would RUN, not merely pass unit "
                    "tests. Also flag it if the code needlessly reinvents what an installed professional library "
                    "already does, or if it lacks behavioral tests that prove the feature actually works (not just "
                    "that pure functions return values). Respond 'APPROVE' on the first line only if it is production "
                    "quality AND runs end to end; otherwise 'REVISE' followed by a numbered list of concrete fixes."},
                {"role": "user", "content": f"TASK:\n{task}\n\nFILES:\n{inventory}\n\n{wiring_note}\n\nDIFF:\n{diff[:16000]}"},
            ], temperature=0.0)
            if critique.strip().upper().startswith("REVISE"):
                _, more, verified2 = run_loop(
                    model_cfg, ws,
                    f"Apply these review fixes to the current working directory, then re-run the tests to verify:\n{critique}",
                    max_iters=max(6, max_iters // 2),
                    extra_system="You are addressing review feedback on existing code. Make the requested fixes and re-verify.",
                )
                iters += more
                verified = verified or verified2

        do_commit = bool(inputs.get("commit", False))
        diff = working_diff(wd)
        if do_commit:
            git(wd, "-c", "user.email=agent@umbrella", "-c", "user.name=umbrella-code-agent", "commit", "-m", f"code agent: {task[:60]}", "--allow-empty")

        final_wiring = integration_check(ws)
        print(json.dumps({
            "ok": True,
            "summary": f"code agent completed {iters} step(s) via {strategy}; "
                       f"verified={verified}; integrationClean={not final_wiring}",
            "strategy": strategy,
            "verified": verified,
            "integrationClean": not final_wiring,
            "wiringIssues": final_wiring,
            "iterations": iters,
            "workingDir": str(wd),
            "diff": diff[:60000],
        }))
    except Exception as ex:  # noqa: BLE001
        print(json.dumps({"ok": False, "error": f"{type(ex).__name__}: {ex}", "workingDir": str(wd)}))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
