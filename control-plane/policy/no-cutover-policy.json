{
  "id": "umbrella.policy.no-cutover.v1",
  "policyRev": "2026-03-10",
  "description": "Prevent accidental live switch-over while validating umbrella abstraction.",
  "forbiddenCommandPatterns": [
    "setup-umbrella-mirror apply --removed-root ~/.removed",
    "setup-umbrella-mirror apply --removed-root /Users/coolfriend/.removed",
    "scripts/bootstrap/setup-umbrella-mirror apply",
    "removed gateway restart",
    "gateway restart"
  ],
  "allowedTargets": [
    "sources/removed/mirror/removed-root",
    "tmp/fresh-removed-sim",
    "tmp/vanilla-home/.removed"
  ],
  "defaultViolationStatus": "BLOCKED"
}
