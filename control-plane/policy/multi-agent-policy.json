    "memory.promote": {
      "riskClass": "high",
      "approvalMode": "conditional",
      "memoryAccess": "durable-memory"
    },
    "memory.hydrate": {
      "riskClass": "high",
      "approvalMode": "conditional",
      "memoryAccess": "durable-memory"
    }
  },
  "agents": {}
}
