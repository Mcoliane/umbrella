{
  "version": "umbrella.model-broker.v1",
  "enabled": true,
  "broker": {
    "url": "",
    "defaultConnectionId": "default",
    "allowFallback": true
  },
  "providers": {
    "zai": {
      "id": "zai",
      "type": "zai",
      "supportsApiKey": true,
      "supportsOAuth": false
    },
    "openai-compatible": {
      "id": "openai-compatible",
      "type": "openai-compatible",
      "supportsApiKey": true,
      "supportsOAuth": false
    }
  },
  "connections": {
    "default": {
      "id": "default",
      "providerId": "zai",
      "authMode": "api_key",
      "label": "Primary Z.ai Connection",
      "enabled": true,
      "baseUrl": "https://api.z.ai/api/coding/paas/v4",
      "defaultModel": "glm-4.7",
      "timeoutSec": 20
    }
  },
  "routing": {
    "defaultConnectionId": "default",
    "allowFallback": true,
    "packageDefaults": {
      "umbrella.mayor.v1": {
        "model": "glm-4.7"
      },
      "umbrella.originator.v1": {
        "model": "glm-4.7"
      },
      "umbrella.programming-agent.v1": {
        "model": "glm-4.7"
      }
    }
  }
}
