{
  "id": "umbrella.router.runtime-routing.v2",
  "supportedRuntimes": [
    "native",
    "umbrella-agent-runtime",
    "removed"
  ],
  "defaultRuntime": "removed",
  "capabilityReroute": {
    "enabled": true,
    "fallbackByRuntime": {
      "umbrella-agent-runtime": [
        "removed"
      ],
      "native": [
        "removed"
      ],
      "removed": []
    }
  },
  "rules": [
    {"matchAction": "memory.promote", "runtime": "native"},
    {"matchAction": "memory.hydrate", "runtime": "native"},
    {"matchStepPrefix": "prepare", "runtime": "removed"},
    {"matchStepPrefix": "compile", "runtime": "removed"},
    {"matchStepPrefix": "audit", "runtime": "removed"},
    {"matchStepPrefix": "fresh", "runtime": "removed"},
    {"matchStepPrefix": "verify", "runtime": "removed"},
    {"matchStepPrefix": "validate", "runtime": "removed"},
    {"matchStepPrefix": "memory", "runtime": "removed"}
  ],
  "reroute": {
    "enabled": true,
    "fallbackRuntimes": {
      "removed": []
    }
  }
}
