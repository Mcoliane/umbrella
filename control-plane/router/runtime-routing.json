{
  "id": "umbrella.router.runtime-routing.v2",
  "supportedRuntimes": [
    "native",
    "umbrella-agent-runtime"
  ],
  "defaultRuntime": "umbrella-agent-runtime",
  "capabilityReroute": {
    "enabled": false,
    "fallbackByRuntime": {}
  },
  "rules": [
    {"matchAction": "memory.promote", "runtime": "native"},
    {"matchAction": "memory.hydrate", "runtime": "native"}
  ],
  "reroute": {
    "enabled": false,
    "fallbackRuntimes": {}
  }
}
