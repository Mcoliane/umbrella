    {"from": "RUNNING", "to": "SUCCEEDED"},
    {"from": "RUNNING", "to": "FAILED"},
    {"from": "RUNNING", "to": "BLOCKED"},
    {"from": "RETRYING", "to": "FAILED"},
    {"from": "RETRYING", "to": "BLOCKED"}
