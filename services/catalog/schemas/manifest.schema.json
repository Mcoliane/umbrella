{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "umbrella.catalog.manifest.v1",
  "title": "Umbrella Catalog Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "apiVersion",
    "kind",
    "runtime",
    "entrypoint",
    "actions"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "apiVersion": { "const": "umbrella.catalog.manifest.v1" },
    "kind": { "enum": ["skill", "plugin"] },
    "runtime": { "enum": ["shell", "python", "http", "container"] },
    "entrypoint": { "type": "string", "minLength": 1 },
    "defaultEnabled": { "type": "boolean" },
    "isolationMode": { "type": "string" },
    "compatibility": {
      "type": "object",
      "properties": {
        "umbrella": {
          "type": "object",
          "properties": {
            "minVersion": { "type": "string" },
            "maxVersion": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "sessionHooks": { "type": "object" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "requiredCapabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "policyHints": { "type": "object" },
          "inputSchema": { "type": "object" },
          "outputSchema": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
