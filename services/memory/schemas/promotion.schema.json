{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "umbrella.memory.service.promotion.v1",
  "type": "object",
  "required": ["source"],
  "properties": {
    "source": {
      "type": "object",
      "required": ["namespace", "key"],
      "properties": {
        "namespace": {"type": "string"},
        "key": {"type": "string"},
        "value": {},
        "metadata": {"type": "object"}
      },
      "additionalProperties": true
    },
    "target": {
      "type": "object",
      "properties": {
        "namespace": {"type": "string"},
        "node_id": {"type": "string"},
        "kind": {"type": "string"},
        "title": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}},
        "source": {"type": "string"}
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "properties": {
        "runId": {"type": "string"},
        "stepId": {"type": "string"},
        "idempotencyKey": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
