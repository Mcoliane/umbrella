#!/usr/bin/env python3
import argparse
import json
import re
from datetime import datetime, timezone
from pathlib import Path


DATE_RE = re.compile(r'^\d{4}-\d{2}-\d{2}$')


def parse_iso_date(text: str):
    if not DATE_RE.match(text or ''):
        return None
    try:
        return datetime.strptime(text, '%Y-%m-%d').replace(tzinfo=timezone.utc)
    except Exception:
        return None


def main() -> int:
    ap = argparse.ArgumentParser(description='Drift lint for control-plane policy metadata and revision markers.')
    ap.add_argument('--umbrella-root', default=str(Path(__file__).resolve().parents[2]))
    ap.add_argument('--umbrella-policy', default='umbrella/policies/default.policy.yaml')
    ap.add_argument('--max-rev-age-days', type=int, default=365)
    args = ap.parse_args()

    root = Path(args.umbrella_root).resolve()
    umbrella_policy_path = root / args.umbrella_policy

    errors = []
    warnings = []

    umbrella_policy_text = ''
    if umbrella_policy_path.exists():
        umbrella_policy_text = umbrella_policy_path.read_text(encoding='utf-8')
    else:
        errors.append(f'missing umbrella policy file: {umbrella_policy_path}')

    up_rev = ''
    for line in umbrella_policy_text.splitlines():
        if line.strip().startswith('policy_rev:'):
            up_rev = line.split(':', 1)[1].strip()
            break
    if not parse_iso_date(up_rev):
        errors.append(f'umbrella default policy missing/invalid policy_rev: {up_rev!r}')
    else:
        age_days = (datetime.now(timezone.utc) - parse_iso_date(up_rev)).days
        if age_days > args.max_rev_age_days:
            warnings.append(f'umbrella default policy revision appears stale ({age_days}d): {up_rev}')

    status = 'PASS' if not errors else 'FAILED'
    out = {
        'status': status,
        'umbrellaPolicyPath': str(umbrella_policy_path),
        'errorCount': len(errors),
        'warningCount': len(warnings),
        'errors': errors,
        'warnings': warnings,
        'umbrellaPolicyRev': up_rev,
        'checkedAt': datetime.now(timezone.utc).isoformat(),
    }
    print(json.dumps(out, indent=2))
    return 0 if status == 'PASS' else 2


if __name__ == '__main__':
    raise SystemExit(main())
