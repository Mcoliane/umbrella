def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def load_referenced_tests(contract_gate_path: Path) -> list[str]:
    """Test names the contract-gate runner claims to run (parsed from its text)."""
    tests: list[str] = []
    for raw in contract_gate_path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if "tests/contract/test-" not in line:
            continue
        start = line.find("test-")
        end = line.find(".sh", start)
        if start == -1 or end == -1:
            continue
        tests.append(line[start : end + 3])
    return sorted(set(tests))


def load_tests_on_disk(tests_dir: Path) -> list[str]:
    """Test files that actually exist in tests/contract/."""
    if not tests_dir.is_dir():
        return []
    return sorted(p.name for p in tests_dir.glob("test-*.sh") if p.is_file())


def missing(root: Path, rel_paths: Iterable[str]) -> list[str]:
    out: list[str] = []
    for rel in rel_paths:
        if not (root / rel).exists():
            out.append(rel)
    return out


def main() -> int:
    ap = argparse.ArgumentParser(description="Verify Umbrella0.4 pattern representation coverage.")
    ap.add_argument("--umbrella-root", default=str(Path(__file__).resolve().parents[2]))
    ap.add_argument("--contract-gate", default="tests/contract/run-all-contracts.sh")
    ap.add_argument("--require-docs", action="store_true")
    args = ap.parse_args()

    root = Path(args.umbrella_root).resolve()
    contract_gate_path = root / args.contract_gate
    tests_dir = root / "tests" / "contract"

    referenced_tests = load_referenced_tests(contract_gate_path) if contract_gate_path.exists() else []
    tests_on_disk = load_tests_on_disk(tests_dir)
    on_disk_set = set(tests_on_disk)

    # A pattern's coverage only counts when the test both exists on disk and
    # is wired into the gate. Entries the runner references but that do not
    # exist are phantoms: they used to silently certify FULL coverage over a
    # gate that could not run.
    phantom_tests = [t for t in referenced_tests if t not in on_disk_set]
    contract_tests = [t for t in referenced_tests if t in on_disk_set]
    non_executable_tests = [
        t for t in contract_tests if not os.access(tests_dir / t, os.X_OK)
    ]

    docs_required = (
        "docs/pattern-closure-plan.md",
        "docs/pattern-evidence.md",
    )

    rows = []
    overall_ok = True
    if phantom_tests or non_executable_tests:
        overall_ok = False
    for rule in PATTERNS:
        missing_files = missing(root, rule.required_files)
        missing_tests = [t for t in rule.required_contract_tests if t not in contract_tests]
        status = "FULL" if not missing_files and not missing_tests else "PARTIAL"
        if status != "FULL":
            overall_ok = False
        rows.append(
            {
                "patternKey": rule.key,
                "patternName": rule.name,
                "status": status,
                "missingFiles": missing_files,
                "missingContractTests": missing_tests,
                "requiredFiles": list(rule.required_files),
                "requiredContractTests": list(rule.required_contract_tests),
            }
        )

    docs_missing: list[str] = []
    if args.require_docs:
        docs_missing = missing(root, docs_required)
        if docs_missing:
            overall_ok = False

    payload = {
        "ok": overall_ok and not docs_missing,
        "status": "PASS" if overall_ok and not docs_missing else "FAILED",
        "umbrellaRoot": str(root),
        "contractGate": str(contract_gate_path),
        "contractTestCount": len(contract_tests),
        "contractTestsOnDiskCount": len(tests_on_disk),
        "phantomContractTests": phantom_tests,
        "nonExecutableContractTests": non_executable_tests,
        "docsRequired": bool(args.require_docs),
        "docsMissing": docs_missing,
        "patterns": rows,
        "checkedAt": now_iso(),
    }
    print(json.dumps(payload, indent=2))
    return 0 if payload["ok"] else 2


if __name__ == "__main__":
    raise SystemExit(main())
