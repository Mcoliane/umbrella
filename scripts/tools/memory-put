#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import urllib.request


def post_json(url: str, payload: dict, token: str) -> dict:
    req = urllib.request.Request(url, method='POST', data=json.dumps(payload).encode('utf-8'))
    req.add_header('Content-Type', 'application/json')
    if token:
        req.add_header('Authorization', f'Bearer {token}')
    with urllib.request.urlopen(req, timeout=20) as resp:
        return json.loads(resp.read().decode('utf-8'))


def main() -> int:
    ap = argparse.ArgumentParser(description='Create memory node in Umbrella memory service')
    ap.add_argument('--base-url', default=os.environ.get('UMBRELLA_MEMORY_BASE_URL', 'http://127.0.0.1:8787'))
    ap.add_argument('--namespace', required=True)
    ap.add_argument('--node-id', required=True)
    ap.add_argument('--kind', default='note')
    ap.add_argument('--title', required=True)
    ap.add_argument('--content', default='')
    ap.add_argument('--tags', default='')
    ap.add_argument('--source', default='umbrella')
    ap.add_argument('--token', default=os.environ.get('UMBRELLA_MEMORY_TOKEN', ''))
    args = ap.parse_args()

    ns_payload = {
        'id': args.namespace,
        'owner_type': 'user',
        'owner_id': 'default',
        'visibility': 'private',
        'retention_days': None,
    }
    post_json(f"{args.base_url.rstrip('/')}/v1/namespaces", ns_payload, args.token)

    tags = [t.strip() for t in args.tags.split(',') if t.strip()]
    payload = {
        'node_id': args.node_id,
        'namespace': args.namespace,
        'kind': args.kind,
        'title': args.title,
        'content': args.content,
        'tags': tags,
        'source': args.source,
    }
    out = post_json(f"{args.base_url.rstrip('/')}/v1/nodes", payload, args.token)
    print(json.dumps(out, indent=2))
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
