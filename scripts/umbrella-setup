#!/usr/bin/env python3
"""Umbrella first-run setup wizard.

Gets a new user from a fresh install to a talking town with the fewest
possible steps. Umbrella talks to any OpenAI-compatible /chat/completions
endpoint: you supply a base URL, a model id, and an API key.

Usage:
  umbrella-setup                                       # interactive: prompts for base URL, model, key
  umbrella-setup --base-url URL --model NAME           # take base URL/model from flags; prompt only for the key
  umbrella-setup --base-url URL --model NAME --start   # ...then bring up the platform and open the TUI
  echo "<key>" | umbrella-setup --base-url URL --model NAME  # fully non-interactive (key on stdin)

The key is written to the gitignored model-broker secrets file with 0600
permissions; it is never printed, logged, or committed.
"""
from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path


# Umbrella is provider-agnostic: it drives any OpenAI-compatible
# /chat/completions endpoint. The only connection type the wizard writes is
# "openai-compatible"; the endpoint (base URL) and model are supplied by the
# user via flags or prompts.
PROVIDER_TYPE = 'openai-compatible'
CONNECTION_LABEL = 'OpenAI-compatible'

BANNER = r"""
  ___ Umbrella setup ___________________________________________
 |  A local control plane for agents. Let's get you talking to
 |  your town. This takes about a minute.
 |_____________________________________________________________
"""


def main() -> int:
    ap = argparse.ArgumentParser(description='Umbrella first-run setup wizard')
    ap.add_argument('--umbrella-root', default=str(Path(__file__).resolve().parents[1]))
    ap.add_argument('--provider', default=PROVIDER_TYPE, choices=[PROVIDER_TYPE],
                    help='connection type to configure (only openai-compatible is supported)')
    ap.add_argument('--base-url', default='',
                    help='OpenAI-compatible API base URL (e.g. https://host/v1); '
                         'also read from UMBRELLA_SETUP_BASE_URL')
    ap.add_argument('--model', default='',
                    help='model id to request from the endpoint; '
                         'also read from UMBRELLA_SETUP_MODEL')
    ap.add_argument('--start', action='store_true',
                    help='after saving, bring up the full platform and open the TUI')
    ap.add_argument('--key', default='',
                    help='API key (skips the prompt); also read from UMBRELLA_SETUP_KEY')
    args = ap.parse_args()

    root = Path(args.umbrella_root).resolve()
    sys.path.insert(0, str(root))
    from services import runtime_model  # noqa: E402  (path set above)

    interactive = sys.stdin.isatty()
    if interactive:
        print(BANNER)

    provider_type = args.provider  # only 'openai-compatible'
    label = CONNECTION_LABEL

    already_configured = bool(runtime_model.load_model_broker(root).get('enabled')) and _has_key(root)

    # Connection details. Prefer flags / env for scripting; otherwise prompt when
    # interactive. When a model is already configured these may be left blank to
    # keep the current connection (see the key step below).
    base_url = args.base_url.strip() or os.environ.get('UMBRELLA_SETUP_BASE_URL', '').strip()
    model = args.model.strip() or os.environ.get('UMBRELLA_SETUP_MODEL', '').strip()

    if interactive and not already_configured:
        if not base_url:
            print("Umbrella talks to any OpenAI-compatible /chat/completions endpoint.")
            base_url = input("  API base URL (e.g. https://host/v1): ").strip()
        if not model:
            model = input("  Model id to request: ").strip()

    # The key. Prefer --key / env for scripting; otherwise a VISIBLE prompt
    # (input(), not getpass) so paste works — macOS secure-keyboard entry blocks
    # pasting into hidden getpass prompts. When a model is already configured,
    # entering a key is optional (blank keeps the existing one) so
    # `umbrella-setup --start` works as a plain "start everything" command.
    supplied = args.key.strip() or os.environ.get('UMBRELLA_SETUP_KEY', '').strip()
    if supplied:
        key = supplied
    elif interactive:
        if already_configured:
            print("A model is already configured. Press Enter to keep it, "
                  "or type/paste a new key to switch.")
            key = input("  API key (blank = keep current): ").strip()
        else:
            print("Type or paste your API key, then Enter.")
            print("  (the key is shown as you type so paste works)")
            key = input("  API key: ").strip()
    else:
        key = sys.stdin.readline().strip()

    if key:
        # Switching an already-configured install still needs a base URL + model;
        # prompt for anything not supplied via flags/env.
        if interactive and already_configured:
            if not base_url:
                print("Umbrella talks to any OpenAI-compatible /chat/completions endpoint.")
                base_url = input("  API base URL (e.g. https://host/v1): ").strip()
            if not model:
                model = input("  Model id to request: ").strip()
        if not base_url or not model:
            print("A base URL (--base-url) and model (--model) are required to "
                  "configure a connection.", file=sys.stderr)
            return 1
        # Build the broker config from the canonical default, enable the connection.
        config = runtime_model._default_broker_config()
        config['enabled'] = True
        conn = config['connections']['default']
        conn['providerId'] = provider_type
        conn['enabled'] = True
        conn['label'] = label
        conn['baseUrl'] = base_url
        conn['defaultModel'] = model
        config['routing']['defaultConnectionId'] = 'default'
        config['broker']['defaultConnectionId'] = 'default'
        secrets = {'connections': {'default': {'apiKey': key}}}
        runtime_model.save_model_broker(root, config=config, secrets=secrets)
        print(f"\n  Configured {model} at {base_url}.")
        print("  Key stored (0600) — not committed, not logged.\n")
    elif already_configured:
        print("  Keeping the existing model configuration.\n")
    else:
        print("No API key provided — nothing was changed.", file=sys.stderr)
        return 1

    if args.start:
        return _start_platform(root)

    print("Next:")
    print("  umbrella-manage bringup        # start the core mesh")
    print("  umbrella-tui                   # open the town, press S to start the full stack")
    print("  ...then press n to create a town and say hello to the mayor.")
    print("\nOr re-run with --start to do that automatically.")
    return 0


def _has_key(root: Path) -> bool:
    from services import runtime_model
    try:
        p = runtime_model.model_broker_secrets_path(root)
        if not p.exists():
            return False
        import json
        secrets = json.loads(p.read_text(encoding='utf-8'))
        return bool(((secrets.get('connections') or {}).get('default') or {}).get('apiKey'))
    except Exception:
        return False


def _start_platform(root: Path) -> int:
    stack = root / 'scripts' / 'control-plane' / 'manage-platform-stack'
    tui = root / 'scripts' / 'umbrella-tui'
    print("Starting the full platform (this can take a few seconds)...")
    proc = subprocess.run([str(stack), 'bringup', '--profile', 'full', '--umbrella-root', str(root)])
    if proc.returncode != 0:
        print("Platform bringup failed; check 'umbrella-manage status'.", file=sys.stderr)
        return proc.returncode
    print("Platform up. Opening the town — press n to create one, then talk to the mayor.")
    print("(When you're done, the TUI's X key stops the stack.)\n")
    os.execvp('python3', ['python3', str(tui), '--umbrella-root', str(root)])
    return 0  # unreachable after execvp


if __name__ == '__main__':
    raise SystemExit(main())
